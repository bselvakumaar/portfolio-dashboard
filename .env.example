APP_NAME=Steward Quant Intelligence Platform
APP_ENV=prod
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

DEFAULT_TICKERS=RELIANCE.NS,TCS.NS,HDFCBANK.NS,INFY.NS,ICICIBANK.NS
DATA_PERIOD=6mo
DATA_INTERVAL=1d
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=1.5

# Optional scoring override (must sum to 100 for strict 0-100 weighting discipline)
SCORING_WEIGHTS_JSON={"momentum":30,"trend_strength":20,"volume_strength":20,"rsi_strength":10,"volatility_control":10,"ai_sentiment":10}

AI_SENTIMENT_PROVIDER=stub

ENABLE_SHEETS_UPDATE=true
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_SHEETS_RANGE=Scores!A1

# Option A: mount service account key file (recommended on Cloud Run with Secret Manager volume/env)
GOOGLE_SERVICE_ACCOUNT_FILE=

# Option B: pass JSON string directly as secret env var
GOOGLE_SERVICE_ACCOUNT_JSON=

# Trading engine config (local JSON store now; replace with Supabase in next step)
TRADING_STORE_FILE=app/data/trading_store.json
TRADING_DATABASE_URL=
APP_ENCRYPTION_KEY=
TRADING_DATABASE_URL_ENCRYPTED=
TRADING_DATABASE_SCHEMA=stock-dashboard
TRADING_BROKERAGE_RATE=0.001
TRADING_SELL_CHARGE_RATE=0.0015
TRADING_MIN_BROKERAGE=20

JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=720
SUPERADMIN_EMAIL=admin@steward.local
SUPERADMIN_PASSWORD=ChangeMeNow#123
